---
import { transliterate } from '../utils/transliterate';

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const tagSlug = transliterate(tag);
---

<a
  href={`/tags/${tagSlug}/`}
  class="font-mono text-xs border border-current px-3 py-1.5 hover:bg-black hover:text-white transition-colors min-h-[44px] inline-flex items-center"
>
  #{tag}
</a>
