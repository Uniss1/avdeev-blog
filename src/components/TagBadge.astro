---
import { transliterate } from '../utils/transliterate';

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const tagSlug = transliterate(tag);
const normalizePath = (value: string) => {
  const withTrailingSlash = value.endsWith('/') ? value : `${value}/`;
  return withTrailingSlash.replace(/\/{2,}/g, '/');
};
const href = `/tags/${tagSlug}/`;
const isActive = normalizePath(Astro.url.pathname) === normalizePath(href);
---

<a
  href={href}
  aria-current={isActive ? 'page' : undefined}
  class:list={[
    'min-h-[44px] inline-flex items-center border px-3 py-2 font-mono text-[11px] uppercase tracking-[0.05em] transition-colors',
    isActive
      ? 'bg-black text-white border-black'
      : 'bg-white/80 text-black hover:bg-black hover:text-white border-black/30 hover:border-black',
  ]}
>
  #{tag}
</a>
