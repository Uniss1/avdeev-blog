---
import { ArrowLeft } from '@lucide/astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<a
  href={base}
  class="mb-8 font-mono text-sm border-2 border-black px-4 py-2.5 hover:bg-black hover:text-white transition-colors inline-flex items-center gap-2 font-bold min-h-[44px]"
>
  <ArrowLeft class="w-4 h-4" />
  НАЗАД
</a>
