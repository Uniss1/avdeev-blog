---
import { getCollection } from 'astro:content';
import TagBadge from './TagBadge.astro';

const notes = await getCollection('notes');
const allTags = [...new Set(notes.flatMap((note) => note.data.tags))].sort();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!-- Desktop: статичный sidebar -->
<aside class="hidden md:flex w-72 h-screen sticky top-0 border-r-2 border-black bg-white/95 flex-col z-20 shrink-0">
  <div class="p-8 flex-1 overflow-y-auto">
    <div class="mb-12 text-center bujo-header-box pb-6">
      <div class="font-display font-black uppercase text-4xl text-black mb-2 tracking-tight">
        Индекс
      </div>
      <p class="font-mono text-[10px] tracking-[0.2em] uppercase font-bold">
        Техническая База Знаний
      </p>
    </div>

    <nav class="space-y-10">
      <div class="bujo-box">
        <div class="bujo-header-box bg-black text-white p-2 text-center font-display font-bold uppercase text-lg tracking-wider">
          Навигация
        </div>
        <ul class="p-4 space-y-3 font-mono text-sm">
          <li>
            <a href={base} class="w-full flex items-center justify-between group hover:font-bold min-h-[44px]">
              <span>Обзор</span>
              <span class="text-xs group-hover:text-black">01</span>
            </a>
          </li>
          <li>
            <a href={`${base}notes/`} class="w-full flex items-center justify-between group hover:font-bold min-h-[44px]">
              <span>Все записи</span>
              <span class="text-xs group-hover:text-black">02</span>
            </a>
          </li>
        </ul>
      </div>

      <div class="bujo-box">
        <div class="bujo-header-box p-2 text-center font-display font-bold uppercase text-lg tracking-wider">
          Темы
        </div>
        <div class="p-4 flex flex-col gap-2 font-mono text-sm">
          {allTags.map((tag) => (
            <TagBadge tag={tag} />
          ))}
        </div>
      </div>
    </nav>
  </div>

  <div class="p-6 border-t-2 border-black font-mono text-[10px] text-center uppercase tracking-widest font-bold bg-white">
    Публичный Ресурс
  </div>
</aside>

<!-- Mobile: сворачиваемая панель details/summary -->
<div class="md:hidden border-b-2 border-black bg-white/95 z-20 relative">
  <details class="sidebar-mobile group">
    <summary class="flex items-center justify-between px-6 min-h-[56px] cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
      <div class="flex items-center gap-3">
        <div class="font-display font-black uppercase text-xl text-black tracking-tight">
          Индекс
        </div>
        <span class="font-mono text-[9px] tracking-[0.15em] uppercase font-bold opacity-60">
          База Знаний
        </span>
      </div>
      <div class="sidebar-chevron transition-transform duration-200 group-open:rotate-180">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square">
          <path d="M5 8l5 5 5-5" />
        </svg>
      </div>
    </summary>

    <div class="border-t-2 border-black p-6 space-y-6">
      <!-- Навигация -->
      <div class="bujo-box">
        <div class="bujo-header-box bg-black text-white p-2 text-center font-display font-bold uppercase text-base tracking-wider">
          Навигация
        </div>
        <ul class="p-4 space-y-1 font-mono text-sm">
          <li>
            <a href={base} class="w-full flex items-center justify-between group hover:font-bold min-h-[44px] py-2">
              <span>Обзор</span>
              <span class="text-xs group-hover:text-black">01</span>
            </a>
          </li>
          <li>
            <a href={`${base}notes/`} class="w-full flex items-center justify-between group hover:font-bold min-h-[44px] py-2">
              <span>Все записи</span>
              <span class="text-xs group-hover:text-black">02</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Темы -->
      <div class="bujo-box">
        <div class="bujo-header-box p-2 text-center font-display font-bold uppercase text-base tracking-wider">
          Темы
        </div>
        <div class="p-4 flex flex-wrap gap-2 font-mono text-sm">
          {allTags.map((tag) => (
            <TagBadge tag={tag} />
          ))}
        </div>
      </div>
    </div>
  </details>
</div>
