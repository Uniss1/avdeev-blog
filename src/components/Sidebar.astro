---
import { getCollection } from 'astro:content';
import TagBadge from './TagBadge.astro';

const notes = await getCollection('notes');
const allTags = [...new Set(notes.flatMap((note) => note.data.tags))].sort();
const normalizePath = (value: string) => {
  const withTrailingSlash = value.endsWith('/') ? value : `${value}/`;
  return withTrailingSlash.replace(/\/{2,}/g, '/');
};

const currentPath = normalizePath(Astro.url.pathname);
const navItems = [
  { href: '/', label: 'Обзор', index: '01' },
  { href: '/notes/', label: 'Все записи', index: '02' },
];
---

<aside class="hidden md:flex w-[18.5rem] xl:w-80 h-screen sticky top-0 border-r-2 border-black bg-white/90 backdrop-blur-sm flex-col z-20 shrink-0">
  <div class="p-6 xl:p-8 flex-1 overflow-y-auto">
    <div class="mb-10 xl:mb-12 text-left bujo-header-box pb-6">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="font-mono text-[10px] tracking-[0.28em] uppercase font-bold opacity-60 mb-3">
            Полевая Сборка
          </p>
          <div class="font-display font-black uppercase text-4xl xl:text-[2.7rem] text-black tracking-tight leading-none">
            Индекс
          </div>
        </div>
        <div class="mt-1 h-3 w-3 rounded-full border-2 border-black bg-black"></div>
      </div>
      <p class="font-mono text-[11px] tracking-[0.22em] uppercase font-bold mt-4">
        Техническая База Знаний
      </p>
      <p class="mt-4 max-w-[18rem] font-sans text-sm leading-relaxed text-black/70">
        Короткие технические разборы по BI, данным, AI и архитектурным решениям.
      </p>
    </div>

    <nav class="space-y-8">
      <div class="bujo-box">
        <div class="bujo-header-box bg-black text-white px-3 py-2 text-center font-display font-bold uppercase text-lg tracking-wider">
          Навигация
        </div>
        <ul class="p-3 space-y-2 font-mono text-sm">
          {navItems.map((item) => {
            const isActive = currentPath === normalizePath(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'w-full min-h-[48px] px-3 py-3 flex items-center justify-between border border-transparent transition-colors',
                    isActive
                      ? 'bg-black text-white border-black'
                      : 'hover:bg-black hover:text-white hover:border-black',
                  ]}
                >
                  <span class="font-bold">{item.label}</span>
                  <span class:list={[
                    'text-[10px] tracking-[0.2em] uppercase',
                    isActive ? 'text-white/70' : 'text-black/50',
                  ]}>
                    {item.index}
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <div class="bujo-box">
        <div class="bujo-header-box px-3 py-2 text-center font-display font-bold uppercase text-lg tracking-wider">
          Темы
        </div>
        <div class="p-4 flex flex-col gap-2 font-mono text-sm">
          {allTags.map((tag) => (
            <TagBadge tag={tag} />
          ))}
        </div>
      </div>
    </nav>
  </div>

  <div class="px-6 py-5 border-t-2 border-black font-mono text-[10px] text-center uppercase tracking-[0.24em] font-bold bg-white">
    Редакционный Архив
  </div>
</aside>

<div class="md:hidden border-b-2 border-black bg-white/95 z-20 relative">
  <details class="sidebar-mobile group">
    <summary class="flex items-center justify-between px-4 sm:px-6 min-h-[56px] cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
      <div class="flex items-center gap-3">
        <div class="font-display font-black uppercase text-xl text-black tracking-tight">
          Индекс
        </div>
        <span class="font-mono text-[10px] tracking-[0.18em] uppercase font-bold opacity-60">
          База Знаний
        </span>
      </div>
      <div class="sidebar-chevron transition-transform duration-200 group-open:rotate-180">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square">
          <path d="M5 8l5 5 5-5" />
        </svg>
      </div>
    </summary>

    <div class="border-t-2 border-black p-4 sm:p-6 space-y-6">
      <div class="bujo-box">
        <div class="bujo-header-box bg-black text-white px-3 py-2 text-center font-display font-bold uppercase text-base tracking-wider">
          Навигация
        </div>
        <ul class="p-3 space-y-2 font-mono text-sm">
          {navItems.map((item) => {
            const isActive = currentPath === normalizePath(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'w-full min-h-[46px] px-3 py-2.5 flex items-center justify-between border border-transparent transition-colors',
                    isActive
                      ? 'bg-black text-white border-black'
                      : 'hover:bg-black hover:text-white hover:border-black',
                  ]}
                >
                  <span class="font-bold">{item.label}</span>
                  <span class:list={[
                    'text-[10px] tracking-[0.2em] uppercase',
                    isActive ? 'text-white/70' : 'text-black/50',
                  ]}>
                    {item.index}
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <div class="bujo-box">
        <div class="bujo-header-box px-3 py-2 text-center font-display font-bold uppercase text-base tracking-wider">
          Темы
        </div>
        <div class="p-4 flex flex-wrap gap-2 font-mono text-sm">
          {allTags.map((tag) => (
            <TagBadge tag={tag} />
          ))}
        </div>
      </div>
    </div>
  </details>
</div>
