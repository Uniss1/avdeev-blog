---
interface Props {
  title?: string;
  headerVariant?: 'default' | 'inverted';
  class?: string;
}

const { title, headerVariant = 'default', class: className } = Astro.props;

const headerClasses = headerVariant === 'inverted'
  ? 'bujo-header-box bg-black text-white p-2 text-center font-display font-bold uppercase text-lg tracking-wider'
  : 'bujo-header-box p-2 text-center font-display font-bold uppercase text-lg tracking-wider';
---

<div class:list={['bujo-box', className]}>
  {title && (
    <div class={headerClasses}>
      {title}
    </div>
  )}
  <slot />
</div>
