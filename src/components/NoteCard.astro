---
import { formatDate } from '../utils/date';
import type { CollectionEntry } from 'astro:content';

interface Props {
  note: CollectionEntry<'notes'>;
}

const { note } = Astro.props;
const dateShort = formatDate(note.data.date, 'short');
const year = note.data.date.getFullYear();
---

<a
  href={`/notes/${note.slug}/`}
  class="bujo-box group block overflow-hidden transition-colors duration-200 hover:bg-black hover:text-white"
>
  <div class="grid md:grid-cols-[8.5rem_minmax(0,1fr)]">
    <div class="border-b-2 md:border-b-0 md:border-r-2 border-black p-5 sm:p-6 flex flex-col justify-between gap-4 group-hover:border-white">
      <div>
        <span class="font-display font-bold text-4xl leading-none">{dateShort}</span>
        <span class="mt-2 block font-mono text-[10px] uppercase tracking-[0.24em]">{year}</span>
      </div>
      <span class="inline-flex w-fit border border-current px-2 py-1 font-mono text-[10px] uppercase tracking-[0.2em]">
        {note.data.category}
      </span>
    </div>

    <div class="p-5 sm:p-6 md:px-8 md:py-6 flex flex-col gap-4">
      <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <h3 class="font-sans font-bold text-xl sm:text-2xl leading-tight group-hover:underline decoration-2 underline-offset-4">
          {note.data.title}
        </h3>
        <span class="font-mono text-[10px] uppercase tracking-[0.22em] opacity-70">
          {note.data.type}
        </span>
      </div>

      {note.data.description && (
        <p class="max-w-2xl text-sm sm:text-base leading-relaxed opacity-80">
          {note.data.description}
        </p>
      )}

      <div class="flex flex-wrap gap-2">
        {note.data.tags.map((tag: string) => (
          <span class="font-mono text-[10px] uppercase tracking-[0.08em] border border-current px-2 py-1">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</a>
