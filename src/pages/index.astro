---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { AUTHOR_NAME, AUTHOR_ROLE } from '../consts';

const notes = (await getCollection('notes'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const MONTHS_RU = ['янв', 'фев', 'мар', 'апр', 'май', 'июн', 'июл', 'авг', 'сен', 'окт', 'ноя', 'дек'];
const formatMonth = (d: Date) => `${MONTHS_RU[d.getMonth()]} ${d.getFullYear()}`;

const previews = Object.fromEntries(
  notes.map((n) => [
    n.slug,
    {
      kicker: n.data.category,
      title: n.data.title,
      body: n.data.description ?? '',
      l: formatMonth(n.data.date),
      r: n.data.type,
    },
  ])
);

const currentYear = new Date().getFullYear();
---

<BaseLayout title={AUTHOR_NAME}>
  <main class="page">
    <div class="col">
      <header class="me">
        <h1>{AUTHOR_NAME}</h1>
        <p class="role">{AUTHOR_ROLE}</p>
      </header>

      <section>
        <h2 class="sec-title">Сейчас</h2>
        <p>
          Веду отдел, который занимается ИИ, аналитикой и автоматизацией вокруг&nbsp;1С. Строю внутренние продукты —
          от корпоративной вики с ассистентом до пайплайнов данных и дашбордов.
        </p>
        <p>
          Пишу сюда короткие заметки про то, как это всё устроено изнутри: архитектура, оптимизация, локальные LLM,
          неочевидные грабли в пайплайнах.
        </p>
      </section>

      {notes.length > 0 && (
        <section>
          <h2 class="sec-title">Статьи</h2>
          <ul class="writing">
            {notes.map((n) => (
              <li>
                <a href={`/notes/${n.slug}/`} data-preview={n.slug}>
                  <span class="title">{n.data.title}</span>
                  {n.data.description && <span class="desc">{n.data.description}</span>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section>
        <h2 class="sec-title">Рассылка</h2>
        <p>Раз в месяц — коротко о том, что строю и что читаю. Без спама.</p>
        <form
          class="newsletter-form"
          onsubmit="event.preventDefault(); this.querySelector('button').textContent='Готово';"
        >
          <input type="email" placeholder="ваш email" required />
          <button type="submit">Подписаться</button>
        </form>
      </section>

      <section>
        <h2 class="sec-title">Связь</h2>
        <p>
          Писать — <a class="link" href="mailto:hi@avdeev.blog">hi@avdeev.blog</a>.
          Код на <a class="link" href="https://github.com/Uniss1">GitHub</a>,
          подписаться на <a class="link" href="/rss.xml">RSS</a>.
        </p>
      </section>

      <footer class="site-footer">© {currentYear} {AUTHOR_NAME}</footer>
    </div>
  </main>

  <div class="preview" id="preview" aria-hidden="true">
    <div class="preview-inner">
      <div class="preview-kicker" id="pv-kicker">—</div>
      <div class="preview-title" id="pv-title">—</div>
      <div class="preview-body" id="pv-body">—</div>
      <div class="preview-meta">
        <span id="pv-meta-l">—</span>
        <span id="pv-meta-r">—</span>
      </div>
    </div>
  </div>

  <script type="application/json" id="previews-data" set:html={JSON.stringify(previews)} />

  <script is:inline>
    (function () {
      if (window.matchMedia('(hover: none)').matches) return;

      const dataEl = document.getElementById('previews-data');
      if (!dataEl) return;
      const PREVIEWS = JSON.parse(dataEl.textContent || '{}');

      const preview = document.getElementById('preview');
      const pvKicker = document.getElementById('pv-kicker');
      const pvTitle = document.getElementById('pv-title');
      const pvBody = document.getElementById('pv-body');
      const pvMetaL = document.getElementById('pv-meta-l');
      const pvMetaR = document.getElementById('pv-meta-r');

      let visible = false;
      let targetX = 0, targetY = 0;
      let x = 0, y = 0;
      let raf = null;

      function loop() {
        x += (targetX - x) * 0.22;
        y += (targetY - y) * 0.22;
        preview.style.transform = `translate3d(${x}px, ${y}px, 0) scale(1)`;
        if (visible && (Math.abs(targetX - x) > 0.2 || Math.abs(targetY - y) > 0.2)) {
          raf = requestAnimationFrame(loop);
        } else {
          raf = null;
        }
      }

      function positionFor(e) {
        const w = 280, h = 170, pad = 18;
        let px = e.clientX + pad;
        let py = e.clientY + pad;
        if (px + w + 12 > window.innerWidth) px = e.clientX - w - pad;
        if (py + h + 12 > window.innerHeight) py = e.clientY - h - pad;
        return { px, py };
      }

      function show(key, px, py) {
        const data = PREVIEWS[key];
        if (!data) return;
        pvKicker.textContent = data.kicker || '';
        pvTitle.textContent = data.title || '';
        pvBody.textContent = data.body || '';
        pvMetaL.textContent = data.l || '';
        pvMetaR.textContent = data.r || '';
        targetX = px;
        targetY = py;
        if (!visible) {
          x = px;
          y = py;
          preview.style.transform = `translate3d(${x}px, ${y}px, 0) scale(.96)`;
          requestAnimationFrame(() => preview.classList.add('show'));
          visible = true;
        }
        if (!raf) loop();
      }

      function hide() {
        preview.classList.remove('show');
        visible = false;
      }

      document.querySelectorAll('[data-preview]').forEach((el) => {
        el.addEventListener('mouseenter', (e) => {
          const { px, py } = positionFor(e);
          show(el.dataset.preview, px, py);
        });
        el.addEventListener('mousemove', (e) => {
          const { px, py } = positionFor(e);
          targetX = px;
          targetY = py;
          if (!raf) loop();
        });
        el.addEventListener('mouseleave', hide);
      });
    })();
  </script>
</BaseLayout>
