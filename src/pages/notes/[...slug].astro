---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { AUTHOR_NAME, AUTHOR_ROLE } from '../../consts';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();

const allNotes = (await getCollection('notes'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const alsoRead = allNotes.filter((n) => n.slug !== note.slug).slice(0, 3);

const MONTHS_RU = [
  'января', 'февраля', 'марта', 'апреля', 'мая', 'июня',
  'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря',
];
const d = note.data.date;
const dateLabel = `${d.getDate()} ${MONTHS_RU[d.getMonth()]} ${d.getFullYear()}`;
---

<BaseLayout
  title={note.data.title}
  description={note.data.description}
  type="article"
  publishedDate={note.data.date}
>
  <main class="page page-article">
    <div class="col col-article">
      <header class="me">
        <h1><a href="/">{AUTHOR_NAME}</a></h1>
        <p class="role">{AUTHOR_ROLE}</p>
      </header>

      <h2 class="article-title">{note.data.title}</h2>
      <p class="article-date">{dateLabel}</p>

      <article>
        <Content />
      </article>

      {alsoRead.length > 0 && (
        <section class="also">
          <h2>Читайте также</h2>
          <ul>
            {alsoRead.map((n) => (
              <li>
                <a href={`/notes/${n.slug}/`}>
                  {n.data.title}
                  {n.data.description && <span class="desc">{n.data.description}</span>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </main>
</BaseLayout>
