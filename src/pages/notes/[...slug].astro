---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackButton from '../../components/BackButton.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
const dateFormatted = formatDate(note.data.date, 'full');
const metric = note.data.metrics;
const metricBefore = typeof metric?.before === 'number' ? metric.before.toLocaleString('ru-RU') : null;
const metricAfter = typeof metric?.after === 'number' ? metric.after.toLocaleString('ru-RU') : null;
const metricValue = typeof metric?.value === 'number' ? metric.value.toLocaleString('ru-RU') : null;
---

<BaseLayout title={note.data.title} description={note.data.description} type="article" publishedDate={note.data.date}>
  <div class="max-w-4xl mx-auto pt-4 md:pt-8 pb-16 md:pb-20">
    <BackButton />

    <article class="bujo-box overflow-hidden">
      <header class="bujo-header-box bg-black text-white p-5 sm:p-8 md:p-12">
        <div class="flex flex-col gap-6">
          <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div class="font-mono text-[11px] sm:text-xs tracking-[0.28em] uppercase border-b border-white/30 pb-3 inline-flex">
              Запись // {dateFormatted}
            </div>
            <div class="font-mono text-[10px] uppercase tracking-[0.24em] text-white/60">
              {note.data.category} / {note.data.type}
            </div>
          </div>

          <h1 class="font-display font-black uppercase text-2xl sm:text-3xl md:text-5xl leading-[0.95] break-words max-w-3xl">
            {note.data.title}
          </h1>

          <div class="flex flex-wrap gap-2.5">
            {note.data.tags.map((tag: string) => (
              <span class="font-mono text-[10px] uppercase tracking-[0.08em] border border-white px-3 py-1.5 bg-white text-black font-bold">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      </header>

      <section data-note-summary class="grid gap-4 border-b-2 border-black bg-white/90 px-5 py-5 sm:px-8 sm:py-6 md:px-12 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.24em] text-black/60">Контекст</div>
          <p class="mt-3 max-w-2xl text-sm sm:text-base md:text-lg leading-relaxed text-black/80">
            {note.data.description ?? `Запись по теме ${note.data.category} с фокусом на ${note.data.type.toLowerCase()}.`}
          </p>
        </div>

        {metric && (
          <div data-note-metric class="bujo-panel-inverse w-full md:w-auto md:min-w-[15rem] p-4">
            <div class="font-mono text-[10px] uppercase tracking-[0.24em] text-white/60">
              {metric.label}
            </div>
            <div class="mt-4 grid gap-3 text-sm">
              {metricBefore && metricAfter && (
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-white/60">До</div>
                    <div class="mt-1 font-display text-2xl leading-none">{metricBefore}</div>
                  </div>
                  <div>
                    <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-white/60">После</div>
                    <div class="mt-1 font-display text-2xl leading-none">{metricAfter}</div>
                  </div>
                </div>
              )}
              {metricValue && (
                <div>
                  <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-white/60">Значение</div>
                  <div class="mt-1 font-display text-3xl leading-none">{metricValue}</div>
                </div>
              )}
            </div>
          </div>
        )}
      </section>

      <div class="p-5 sm:p-8 md:p-12 prose prose-black max-w-none overflow-hidden">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
