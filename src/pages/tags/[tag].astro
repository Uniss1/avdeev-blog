---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoteCard from '../../components/NoteCard.astro';
import { getCollection } from 'astro:content';
import { transliterate } from '../../utils/transliterate';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  const tagMap = new Map<string, { tag: string; slug: string }>();

  notes.forEach((note) => {
    note.data.tags.forEach((tag: string) => {
      const slug = transliterate(tag);
      if (!tagMap.has(slug)) {
        tagMap.set(slug, { tag, slug });
      }
    });
  });

  return Array.from(tagMap.values()).map(({ tag, slug }) => ({
    params: { tag: slug },
    props: { originalTag: tag },
  }));
}

interface Props {
  originalTag: string;
}

const { originalTag } = Astro.props;

const notes = (await getCollection('notes'))
  .filter((note) => note.data.tags.includes(originalTag))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`Тема: #${originalTag}`} description={`Записи по теме «${originalTag}»: технические заметки и решения.`}>
  <div class="max-w-6xl mx-auto space-y-8 md:space-y-10">
    <section class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_18rem] xl:items-end">
      <div class="space-y-4">
        <div class="font-mono text-[10px] uppercase tracking-[0.26em] text-black/60">Фильтр По Теме</div>
        <h1 class="font-display font-black uppercase text-4xl sm:text-5xl md:text-6xl text-black leading-[0.92]">
          #{originalTag}
        </h1>
        <p class="max-w-2xl text-base sm:text-lg leading-relaxed text-black/80">
          Подборка материалов, где тема «{originalTag}» не мелькает вскользь, а действительно определяет содержание заметки.
        </p>
      </div>

      <aside class="bujo-box p-5 sm:p-6">
        <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-black/60">Материалов</div>
        <div class="mt-3 font-display text-4xl leading-none">{notes.length}</div>
      </aside>
    </section>

    <div class="space-y-5">
      {notes.map((note) => (
        <NoteCard note={note} />
      ))}
    </div>
  </div>
</BaseLayout>
